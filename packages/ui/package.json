{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**",
    "dist"
  ],
  "exports": {
    "./components/button": {
      "import": {
        "types": "./dist/components/button/index.d.mts",
        "default": "./dist/components/button/index.mjs"
      }
    },
    "./components/dropdown-menu": {
      "import": {
        "types": "./dist/components/dropdown-menu/index.mts",
        "default": "./dist/components/dropdown-menu/index.mjs"
      }
    },
    "./components/theme-provider": {
      "import": {
        "types": "./dist/components/theme-provider/index.mts",
        "default": "./dist/components/theme-provider/index.mjs"
      }
    },
    "./hooks/use-mounted": {
      "import": {
        "types": "./dist/hooks/use-mounted/index.mts",
        "default": "./dist/hooks/use-mounted/index.mjs"
      }
    },
    "./lib/utils": {
      "import": {
        "types": "./dist/lib/utils/index.mts",
        "default": "./dist/lib/utils/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "lint:js": "oxlint . --report-unused-disable-directives --max-warnings 0",
    "lint": "run-p lint:js",
    "generate:component": "turbo gen react-component"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "next-themes": "0.4.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "2.10.5",
    "@types/react-dom": "19.2.3",
    "npm-run-all2": "9.0.2",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
